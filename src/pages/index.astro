---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Digital Alchemist | Interactive Portfolio">
  <!-- Hero Section - Laboratory Entrance -->
  <section id="laboratory" class="relative h-screen flex items-center justify-center overflow-hidden">
    <!-- 3D Canvas Container -->
    <div id="hero-canvas" class="absolute inset-0 z-0"></div>
    
    <!-- Particle Background -->
    <div class="absolute inset-0 z-10">
      <div class="particle-container">
        {Array.from({ length: 50 }, (_, i) => (
          <div 
            class="particle absolute w-1 h-1 bg-electric-cyan rounded-full animate-particle-float"
            style={`
              left: ${Math.random() * 100}%;
              top: ${Math.random() * 100}%;
              animation-delay: ${Math.random() * 4}s;
              animation-duration: ${4 + Math.random() * 2}s;
            `}
          />
        ))}
      </div>
    </div>

    <!-- Hero Content -->
    <div class="relative z-20 text-center max-w-4xl mx-auto px-6">
      <div class="mb-8">
        <h1 class="text-6xl md:text-8xl font-mono font-bold text-electric-cyan mb-4">
          <span class="inline-block animate-float" style="animation-delay: 0s;">D</span>
          <span class="inline-block animate-float" style="animation-delay: 0.1s;">I</span>
          <span class="inline-block animate-float" style="animation-delay: 0.2s;">G</span>
          <span class="inline-block animate-float" style="animation-delay: 0.3s;">I</span>
          <span class="inline-block animate-float" style="animation-delay: 0.4s;">T</span>
          <span class="inline-block animate-float" style="animation-delay: 0.5s;">A</span>
          <span class="inline-block animate-float" style="animation-delay: 0.6s;">L</span>
        </h1>
        <h2 class="text-4xl md:text-6xl font-mono font-bold text-holographic-pink mb-6">
          <span class="animate-hologram">ALCHEMIST</span>
        </h2>
      </div>
      
      <p class="text-xl md:text-2xl text-warm-white/80 mb-8 font-sans">
        Transforming ideas into <span class="text-lab-green">interactive experiences</span>
      </p>
      
      <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
        <button id="enter-lab" class="px-8 py-4 bg-electric-cyan/20 border-2 border-electric-cyan text-electric-cyan font-mono font-bold rounded-lg hover:bg-electric-cyan hover:text-space-blue transition-all duration-300 animate-pulse-glow">
          ENTER LABORATORY
        </button>
        <button id="view-experiments" class="px-8 py-4 border-2 border-holographic-pink text-holographic-pink font-mono font-bold rounded-lg hover:bg-holographic-pink hover:text-space-blue transition-all duration-300">
          VIEW EXPERIMENTS
        </button>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-20">
      <div class="flex flex-col items-center text-electric-cyan/70">
        <span class="font-mono text-sm mb-2">SCROLL TO EXPLORE</span>
        <div class="w-px h-16 bg-electric-cyan/30 relative">
          <div class="w-px h-4 bg-electric-cyan absolute top-0 animate-bounce"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section - DNA Helix -->
  <section id="about" class="min-h-screen py-20 relative">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-6xl font-mono font-bold text-electric-cyan mb-4">
          <span class="animate-hologram">SYNTHESIS</span>
        </h2>
        <p class="text-xl text-warm-white/70 font-sans">
          The molecular structure of creativity
        </p>
      </div>

      <!-- DNA Helix Container -->
      <div id="dna-container" class="relative h-96 mb-16">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-6xl font-mono text-electric-cyan/20">
            Loading DNA sequence...
          </div>
        </div>
      </div>

      <!-- About Content -->
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h3 class="text-2xl font-mono font-bold text-lab-green mb-6">
            The Alchemist's Journey
          </h3>
          <div class="space-y-4 text-warm-white/80 font-sans">
            <p>
              In the digital laboratory where creativity meets technology, I transform abstract concepts into tangible, interactive experiences. Each project is an experiment in pushing the boundaries of what's possible on the web.
            </p>
            <p>
              My expertise spans the full spectrum of digital creation - from conceptual design to technical implementation, with a particular focus on creating immersive 3D experiences that engage and inspire.
            </p>
            <p>
              Every line of code is carefully crafted, every animation purposefully designed, and every interaction thoughtfully considered to create memorable experiences that resonate with users.
            </p>
          </div>
        </div>
        
        <div class="space-y-6">
          <div class="p-6 bg-space-blue/50 border border-electric-cyan/30 rounded-lg backdrop-blur-sm">
            <h4 class="font-mono font-bold text-electric-cyan mb-3">Core Elements</h4>
            <div class="grid grid-cols-2 gap-4 text-sm font-mono">
              <div class="text-lab-green">WebGL/Three.js</div>
              <div class="text-holographic-pink">GSAP Animation</div>
              <div class="text-electric-cyan">React/Vue/Astro</div>
              <div class="text-energy-purple">Node.js/Python</div>
            </div>
          </div>
          
          <div class="p-6 bg-space-blue/50 border border-holographic-pink/30 rounded-lg backdrop-blur-sm">
            <h4 class="font-mono font-bold text-holographic-pink mb-3">Specializations</h4>
            <ul class="space-y-2 text-sm font-sans text-warm-white/80">
              <li>• Interactive 3D Experiences</li>
              <li>• Creative Web Development</li>
              <li>• Motion Design & Animation</li>
              <li>• Performance Optimization</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section - Periodic Table -->
  <section id="formulas" class="min-h-screen py-20 relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-6xl font-mono font-bold text-holographic-pink mb-4">
          <span class="animate-hologram">FORMULAS</span>
        </h2>
        <p class="text-xl text-warm-white/70 font-sans">
          The periodic table of digital elements
        </p>
      </div>

      <!-- Periodic Table Container -->
      <div id="periodic-table" class="relative">
        <div class="grid grid-cols-8 md:grid-cols-12 gap-2 max-w-4xl mx-auto">
          <!-- Skills will be populated by JavaScript -->
        </div>
      </div>

      <!-- Skill Details Panel -->
      <div id="skill-details" class="mt-12 p-6 bg-space-blue/50 border border-electric-cyan/30 rounded-lg backdrop-blur-sm opacity-0 transition-opacity duration-300">
        <h3 id="skill-name" class="text-2xl font-mono font-bold text-electric-cyan mb-4"></h3>
        <div id="skill-description" class="text-warm-white/80 font-sans"></div>
        <div id="skill-proficiency" class="mt-4">
          <div class="flex justify-between items-center mb-2">
            <span class="font-mono text-sm text-warm-white/70">Proficiency</span>
            <span id="skill-level" class="font-mono text-sm text-electric-cyan"></span>
          </div>
          <div class="w-full h-2 bg-warm-white/20 rounded-full overflow-hidden">
            <div id="skill-bar" class="h-full bg-electric-cyan transition-all duration-500"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section - Holographic Displays -->
  <section id="experiments" class="min-h-screen py-20 relative">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-6xl font-mono font-bold text-lab-green mb-4">
          <span class="animate-hologram">EXPERIMENTS</span>
        </h2>
        <p class="text-xl text-warm-white/70 font-sans">
          Digital creations from the laboratory
        </p>
      </div>

      <!-- Projects Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Project cards will be populated by JavaScript -->
      </div>
    </div>
  </section>

  <!-- Contact Section - Communication Portal -->
  <section id="contact" class="min-h-screen py-20 relative">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-6xl font-mono font-bold text-energy-purple mb-4">
          <span class="animate-hologram">TRANSMISSION</span>
        </h2>
        <p class="text-xl text-warm-white/70 font-sans">
          Establish communication protocol
        </p>
      </div>

      <!-- Contact Form -->
      <div class="bg-space-blue/50 border border-energy-purple/30 rounded-lg backdrop-blur-sm p-8">
        <form id="contact-form" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block font-mono text-sm text-electric-cyan mb-2">Name</label>
              <input type="text" required class="w-full bg-space-blue/70 border border-electric-cyan/30 rounded px-4 py-3 text-warm-white font-mono focus:border-electric-cyan focus:outline-none">
            </div>
            <div>
              <label class="block font-mono text-sm text-electric-cyan mb-2">Email</label>
              <input type="email" required class="w-full bg-space-blue/70 border border-electric-cyan/30 rounded px-4 py-3 text-warm-white font-mono focus:border-electric-cyan focus:outline-none">
            </div>
          </div>
          
          <div>
            <label class="block font-mono text-sm text-electric-cyan mb-2">Subject</label>
            <input type="text" required class="w-full bg-space-blue/70 border border-electric-cyan/30 rounded px-4 py-3 text-warm-white font-mono focus:border-electric-cyan focus:outline-none">
          </div>
          
          <div>
            <label class="block font-mono text-sm text-electric-cyan mb-2">Message</label>
            <textarea rows="6" required class="w-full bg-space-blue/70 border border-electric-cyan/30 rounded px-4 py-3 text-warm-white font-mono focus:border-electric-cyan focus:outline-none resize-none"></textarea>
          </div>
          
          <button type="submit" class="w-full py-4 bg-energy-purple/20 border-2 border-energy-purple text-energy-purple font-mono font-bold rounded-lg hover:bg-energy-purple hover:text-space-blue transition-all duration-300 animate-pulse-glow">
            TRANSMIT MESSAGE
          </button>
        </form>
      </div>

      <!-- Social Links -->
      <div class="text-center mt-12">
        <div class="flex justify-center space-x-8">
          <a href="#" class="text-electric-cyan hover:text-warm-white transition-colors duration-300">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="#" class="text-electric-cyan hover:text-warm-white transition-colors duration-300">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="text-electric-cyan hover:text-warm-white transition-colors duration-300">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Import and initialize the main application
  import('../js/app.js').then(module => {
    const app = new module.App();
    app.init();
  });
</script>

<style>
  .particle {
    filter: blur(0.5px);
  }
  
  .particle:nth-child(odd) {
    background: #ff00ff;
  }
  
  .particle:nth-child(3n) {
    background: #00ff88;
  }
  
  /* Glowing text effect */
  .animate-hologram {
    animation: hologram 2s ease-in-out infinite;
    text-shadow: 0 0 10px currentColor;
  }
  
  /* Floating letters */
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
  
  /* Pulse glow effect */
  .animate-pulse-glow {
    animation: pulse-glow 2s ease-in-out infinite alternate;
  }
</style>